{
  "name": "opencode-github-copilot-enterprise-profile",
  "version": "0.1.3",
  "type": "module",
  "description": "OpenCode plugin/runtime for GitHub Copilot Enterprise model catalog and config overlays.",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "opencode-github-copilot-enterprise-profile": "./dist/scripts/install-global.js",
    "opencode-copilot-enterprise-install": "./dist/scripts/install-global.js"
  },
  "exports": {
    "./plugin": "./dist/src/plugin.js",
    "./provider": "./dist/src/provider.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "render-config": "npm run build && node ./dist/scripts/render-config.js",
    "run": "npm run build && node ./dist/scripts/run-opencode.js",
    "install:global": "npm run build && node ./dist/scripts/install-global.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
